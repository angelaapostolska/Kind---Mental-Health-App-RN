{
  "expo": {
    "name": "Kind",
    "slug": "kind-mental-health-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "src/assets/images/icon.png",
    "scheme": "kind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kind.mentalhealth"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "src/assets/images/adaptive-icon.png",
        "backgroundColor": "#f5f3ff"
      },
      "package": "com.kind.mentalhealth"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "src/assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "src/assets/images/splash_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f5f3ff"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}